---
const title = 'OBNM HyperPop Music Project';
const description = 'OBNM HyperPop Music Project. I do not just produce music. I develop artists.';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/assets/oscar-profile.png" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="demo-header">
      <a href="/" class="brand">
        <img src="/assets/logo-obnm.png" alt="OBNM" class="brand-logo" />
        <span class="brand-name">BeatPioneer</span>
      </a>
      <nav class="header-nav" aria-label="Demo navigation">
        <a href="#listen">Listen</a>
        <a href="#contact">Get in touch</a>
      </nav>
    </header>

    <main>
      <section class="hero">
        <div class="hero-grid">
          <figure class="hero-portrait">
            <img src="/assets/oscar-profile.png" alt="OBNM, Oscar Bonomi" loading="eager" />
          </figure>
          <div class="hero-text">
            <p class="eyebrow">OBNM · HyperPop Music Project</p>
            <h1>
              <span class="line">I don't just produce music.</span>
              <span class="line accent">I develop artists.</span>
            </h1>
            <p class="lead">
              Music is the lifeblood of my journey, a tool for personal growth.
            </p>
            <div class="hero-meta">
              <p>
                My sonic exploration is a search for unique connections, between analog and electronic, between African rhythms and contemporary sound design, between funk and minimalism.
              </p>
              <p>
                I believe music is a vehicle for genuine empathy and awareness, a compass to navigate a world saturated with manipulative narratives designed to keep us divided. Music, instead, brings us together.
              </p>
            </div>
          </div>
        </div>
      </section>

      <section id="listen" class="player">
        <div class="container">
          <p class="eyebrow">Listen</p>
          <h2>OBNM · HyperPop</h2>
          <div class="player-frame">
            <iframe
              width="100%"
              height="450"
              scrolling="no"
              frameborder="no"
              allow="autoplay"
              src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/oscar-bonomi/sets/demo-music-project/s-xdQ5TxgxZLZ&color=%23ff1493&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true"
              title="OBNM HyperPop Music Project on SoundCloud"
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </section>

      <section id="contact" class="cta">
        <div class="container">
          <p class="eyebrow">Get in touch</p>
          <h2>Let's build something real.</h2>
          <p class="cta-body">
            If this resonates with you, drop me a line. I read every message.
          </p>
          <a href="mailto:info@beatpioneer.com" class="cta-button">
            <span>info@beatpioneer.com</span>
          </a>
          <nav class="social" aria-label="Social channels">
            <a href="https://www.instagram.com/obnm_beatpioneer/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
            </a>
            <a href="https://soundcloud.com/oscar-bonomi" target="_blank" rel="noopener noreferrer" aria-label="SoundCloud">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 14.5c0 2-1.5 3.5-3.5 3.5h-7c-.3 0-.5-.2-.5-.5V9c0-.2.1-.4.3-.5 1-.4 2.1-.6 3.2-.6 3.7 0 6.7 2.7 7.4 6.2.1.1.1.3.1.4zM8 18H7c-.3 0-.5-.2-.5-.5v-7c0-.3.2-.5.5-.5s.5.2.5.5v7c0 .3-.2.5-.5.5zM5 18h-.5c-.3 0-.5-.2-.5-.5v-6c0-.3.2-.5.5-.5s.5.2.5.5v6c0 .3-.2.5-.5.5zM2 17h-.5c-.3 0-.5-.2-.5-.5v-4c0-.3.2-.5.5-.5s.5.2.5.5v4c0 .3-.2.5-.5.5z"/></svg>
            </a>
            <a href="https://www.youtube.com/@OBNM_BeatPioneer" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 6.4c-.3-1.1-1.1-1.9-2.2-2.2C18.9 3.7 12 3.7 12 3.7s-6.9 0-8.8.5C2.1 4.5 1.3 5.3 1 6.4.5 8.3.5 12 .5 12s0 3.7.5 5.6c.3 1.1 1.1 1.9 2.2 2.2 1.9.5 8.8.5 8.8.5s6.9 0 8.8-.5c1.1-.3 1.9-1.1 2.2-2.2.5-1.9.5-5.6.5-5.6s0-3.7-.5-5.6zM9.7 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg>
            </a>
            <a href="https://www.tiktok.com/@oscarbonomi_obnm" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 6.4c-1.7-.4-3-1.6-3.5-3.2v-.7h-3v12.3c0 1.7-1.4 3-3 3s-3-1.4-3-3 1.4-3 3-3c.3 0 .6 0 .9.1V8.8c-.3 0-.6-.1-.9-.1-3.4 0-6.1 2.7-6.1 6.1S6.7 21 10.1 21s6.1-2.7 6.1-6.1V9.4c1.3.9 2.9 1.5 4.5 1.5V8c-.4 0-.7-.1-1.1-.2v-1.4z"/></svg>
            </a>
          </nav>
        </div>
      </section>
    </main>

    <footer class="demo-footer">
      <div class="footer-inner">
        <a href="/" class="brand">
          <img src="/assets/logo-obnm.png" alt="OBNM" class="brand-logo" />
          <span class="brand-name">BeatPioneer</span>
        </a>
        <p class="legal">© {new Date().getFullYear()} Oscar Bonomi · OBNM · Hamburg</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --neon-magenta: #FF1493;
        --neon-cyan: #00FFFF;
        --electric-blue: #0033FF;
        --dark-base: #0A0E27;
        --dark-card: #141a3a;
        --highlight: #FFFFFF;
        --warm-coral: #FF6B35;
        --purple: #9D4EDD;
        --teal: #3A86FF;
        --font-display: 'Fraunces', Georgia, serif;
        --font-body: 'Inter', system-ui, sans-serif;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--dark-base);
        color: var(--highlight);
        font-family: var(--font-body);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        background:
          radial-gradient(ellipse 900px 600px at 15% 20%, rgba(255, 20, 147, 0.12) 0%, transparent 55%),
          radial-gradient(ellipse 700px 500px at 85% 75%, rgba(0, 255, 255, 0.10) 0%, transparent 55%),
          radial-gradient(ellipse 600px 400px at 50% 100%, rgba(157, 78, 221, 0.08) 0%, transparent 60%),
          var(--dark-base);
        min-height: 100vh;
      }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3 {
        font-family: var(--font-display);
        font-weight: 600;
        letter-spacing: -0.01em;
        line-height: 1.05;
        margin: 0 0 16px;
      }
      .container {
        max-width: 920px;
        margin: 0 auto;
        padding: 0 24px;
      }
      .eyebrow {
        font-family: var(--font-body);
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--neon-cyan);
        margin: 0 0 20px;
      }

      /* HEADER */
      .demo-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: rgba(10, 14, 39, 0.92);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(255, 20, 147, 0.2);
        padding: 4px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }
      .demo-header .brand {
        display: inline-flex;
        align-items: center;
        gap: 0;
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 600;
        color: var(--highlight);
        letter-spacing: -0.01em;
        min-width: 0;
      }
      .demo-header .brand-logo {
        width: 192px;
        height: 192px;
        object-fit: contain;
        display: block;
        border-radius: 50%;
        border: 1px solid var(--neon-cyan);
        box-shadow: 0 0 16px rgba(255, 20, 147, 0.35);
        flex-shrink: 0;
      }
      .demo-header .brand-name { white-space: nowrap; }
      .demo-header .brand:hover .brand-name { color: var(--neon-cyan); }
      .header-nav {
        display: flex;
        gap: 22px;
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }
      .header-nav a {
        color: var(--highlight);
        transition: color 0.25s ease, text-shadow 0.25s ease;
      }
      .header-nav a:hover {
        color: var(--neon-cyan);
        text-shadow: 0 0 12px rgba(0, 255, 255, 0.6);
      }

      /* HERO */
      .hero {
        padding: 240px 24px 80px;
      }
      .hero-grid {
        max-width: 1160px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 56px;
        align-items: center;
      }
      .hero-portrait {
        margin: 0;
        position: relative;
        border: 2px solid var(--neon-cyan);
        border-radius: 14px;
        padding: 6px;
        box-shadow:
          0 0 40px rgba(255, 20, 147, 0.45),
          0 0 80px rgba(0, 255, 255, 0.15);
        background: linear-gradient(135deg, rgba(255, 20, 147, 0.10), rgba(0, 255, 255, 0.06));
      }
      .hero-portrait::before {
        content: '';
        position: absolute;
        inset: -2px;
        border-radius: 14px;
        background: linear-gradient(135deg, var(--neon-magenta), var(--neon-cyan), var(--purple));
        z-index: -1;
        filter: blur(18px);
        opacity: 0.45;
      }
      .hero-portrait img {
        width: 100%;
        height: auto;
        display: block;
        border-radius: 10px;
      }
      .hero-text h1 {
        font-size: clamp(2.25rem, 5vw, 3.25rem);
        font-weight: 700;
        font-variation-settings: "opsz" 144;
        margin: 0 0 24px;
        line-height: 1.05;
      }
      .hero-text h1 .line {
        display: block;
        color: var(--highlight);
      }
      .hero-text h1 .line.accent {
        color: var(--neon-magenta);
        font-style: italic;
        text-shadow: 0 0 24px rgba(255, 20, 147, 0.4);
      }
      .hero-text .lead {
        font-family: var(--font-display);
        font-size: clamp(1.15rem, 2vw, 1.45rem);
        font-style: italic;
        font-weight: 400;
        color: var(--neon-cyan);
        margin: 0 0 28px;
        font-variation-settings: "opsz" 72;
        letter-spacing: 0.01em;
        line-height: 1.4;
      }
      .hero-meta p {
        font-size: 1rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.78);
        margin: 0 0 16px;
        max-width: 540px;
      }

      /* PLAYER */
      .player {
        padding: 80px 0;
        border-top: 1px solid rgba(255, 20, 147, 0.18);
      }
      .player h2 {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
        color: var(--highlight);
        font-weight: 600;
      }
      .player-frame {
        margin-top: 32px;
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--neon-cyan);
        background: var(--dark-card);
        box-shadow: 0 0 32px rgba(0, 255, 255, 0.18);
      }
      .player-frame iframe {
        display: block;
        width: 100%;
        border: 0;
      }

      /* CTA */
      .cta {
        padding: 100px 0 120px;
        border-top: 1px solid rgba(0, 255, 255, 0.18);
        text-align: center;
      }
      .cta .container { max-width: 720px; }
      .cta h2 {
        font-size: clamp(2.25rem, 5vw, 3.25rem);
        font-weight: 700;
        color: var(--neon-magenta);
        text-shadow: 0 0 24px rgba(255, 20, 147, 0.35);
        margin: 0 0 24px;
      }
      .cta-body {
        font-size: 1.0625rem;
        line-height: 1.7;
        color: var(--highlight);
        margin: 0 0 40px;
        max-width: 520px;
        margin-left: auto;
        margin-right: auto;
      }
      .cta-button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--neon-magenta);
        color: var(--highlight);
        font-family: var(--font-body);
        font-weight: 700;
        font-size: 1rem;
        letter-spacing: 0.04em;
        padding: 18px 36px;
        border-radius: 8px;
        border: 2px solid var(--neon-magenta);
        transition: all 0.3s ease;
        box-shadow: 0 0 24px rgba(255, 20, 147, 0.4);
        cursor: pointer;
      }
      .cta-button:hover {
        background: var(--neon-cyan);
        border-color: var(--neon-cyan);
        color: var(--dark-base);
        box-shadow: 0 0 32px rgba(0, 255, 255, 0.55);
        transform: translateY(-2px);
      }
      .social {
        margin-top: 40px;
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        justify-content: center;
      }
      .social a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 46px;
        height: 46px;
        border-radius: 50%;
        background: var(--dark-card);
        border: 1px solid rgba(0, 255, 255, 0.4);
        color: var(--neon-cyan);
        transition: all 0.25s ease;
      }
      .social a:hover {
        border-color: var(--neon-magenta);
        color: var(--neon-magenta);
        box-shadow: 0 0 16px rgba(255, 20, 147, 0.45);
        transform: translateY(-2px);
      }
      .social svg { width: 18px; height: 18px; }

      /* FOOTER */
      .demo-footer {
        background: var(--dark-base);
        border-top: 1px solid var(--neon-magenta);
        padding: 16px 0 14px;
        margin-top: 24px;
      }
      .footer-inner {
        max-width: 1160px;
        margin: 0 auto;
        padding: 0 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
      }
      .footer-inner .brand {
        display: inline-flex;
        align-items: center;
        gap: 0;
        font-family: var(--font-display);
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--neon-cyan);
        letter-spacing: -0.01em;
      }
      .footer-inner .brand-logo {
        width: 192px;
        height: 192px;
        object-fit: contain;
        display: block;
        border-radius: 50%;
        border: 1px solid var(--neon-cyan);
        flex-shrink: 0;
      }
      .footer-inner .brand:hover .brand-name { color: var(--neon-magenta); }
      .footer-inner .legal {
        font-size: 0.7rem;
        color: rgba(255, 255, 255, 0.55);
        letter-spacing: 0.06em;
        margin: 0;
      }

      /* RESPONSIVE */
      @media (max-width: 900px) {
        .hero { padding: 180px 20px 60px; }
        .hero-grid {
          grid-template-columns: 1fr;
          gap: 40px;
        }
        .hero-portrait { max-width: 480px; margin: 0 auto; }
      }
      @media (max-width: 768px) {
        .demo-header { padding: 4px 12px; gap: 8px; }
        .demo-header .brand-logo { width: 56px; height: 56px; }
        .demo-header .brand-name { font-size: 1rem; }
        .footer-inner .brand-logo { width: 56px; height: 56px; }
        .footer-inner .brand-name { font-size: 1rem; }
        .hero { padding: 140px 18px 50px; }
        .player { padding: 56px 0; }
        .player-frame iframe { height: 360px; }
        .cta { padding: 64px 0 80px; }
        .footer-inner { justify-content: center; text-align: center; }
        .footer-inner .legal { font-size: 0.65rem; }
      }
      @media (max-width: 380px) {
        .demo-header .brand-logo { width: 44px; height: 44px; }
        .demo-header .brand-name { font-size: 0.9rem; }
        .footer-inner .brand-logo { width: 44px; height: 44px; }
      }
    </style>
  </body>
</html>
