---
const title = 'OBNM HyperPop Music Project';
const description = 'OBNM HyperPop Music Project, a sonic exploration between analog and electronic, between African rhythms and contemporary sound design.';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/assets/favicon.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/assets/Hero-1.jpg" />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header class="demo-header">
      <a href="/" class="brand">
        <img src="/assets/logo-obnm.png" alt="OBNM" class="brand-logo" />
        <span class="brand-name">BeatPioneer</span>
      </a>
    </header>

    <main>
      <section class="hero">
        <div class="hero-bg">
          <img src="/assets/Hero-1.jpg" alt="" aria-hidden="true" />
          <div class="hero-overlay"></div>
        </div>
        <div class="container hero-content">
          <p class="eyebrow">Music Project</p>
          <h1>OBNM<br /><span class="hl">HyperPop</span><br />Music Project</h1>
        </div>
      </section>

      <section class="manifesto">
        <div class="container">
          <p class="lead">
            Music is the lifeblood of my journey, a tool for personal growth.
          </p>
          <p>
            My sonic exploration is a search for unique connections, between analog and electronic, between African rhythms and contemporary sound design, between funk and minimalism.
          </p>
          <p>
            I believe music is a vehicle for genuine empathy and awareness, a compass to navigate a world saturated with manipulative narratives designed to keep us divided. Music, instead, brings us together.
          </p>
        </div>
      </section>

      <section class="player">
        <div class="container">
          <p class="eyebrow">Listen</p>
          <h2>OBNM · HyperPop Music Project</h2>
          <div class="player-frame">
            <iframe
              width="100%"
              height="450"
              scrolling="no"
              frameborder="no"
              allow="autoplay"
              src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/users/oscar-bonomi&color=%23e8a857&auto_play=false&hide_related=false&show_comments=true&show_user=true&show_reposts=false&show_teaser=true&visual=true"
              title="OBNM HyperPop Music Project on SoundCloud"
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </section>

      <section class="cta">
        <div class="container">
          <figure class="portrait">
            <img src="/assets/Bio-1.jpg" alt="OBNM, Oscar Bonomi" loading="lazy" />
          </figure>
          <div class="cta-text">
            <p class="eyebrow">Get in touch</p>
            <h2>Let's talk</h2>
            <p>
              If this resonates with you, write me. I am OBNM.
            </p>
            <a href="mailto:info@beatpioneer.com" class="email-display">info@beatpioneer.com</a>
            <nav class="social" aria-label="Social channels">
              <a href="https://www.instagram.com/obnm_beatpioneer/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
              </a>
              <a href="https://soundcloud.com/oscar-bonomi" target="_blank" rel="noopener noreferrer" aria-label="SoundCloud">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 14.5c0 2-1.5 3.5-3.5 3.5h-7c-.3 0-.5-.2-.5-.5V9c0-.2.1-.4.3-.5 1-.4 2.1-.6 3.2-.6 3.7 0 6.7 2.7 7.4 6.2.1.1.1.3.1.4zM8 18H7c-.3 0-.5-.2-.5-.5v-7c0-.3.2-.5.5-.5s.5.2.5.5v7c0 .3-.2.5-.5.5zM5 18h-.5c-.3 0-.5-.2-.5-.5v-6c0-.3.2-.5.5-.5s.5.2.5.5v6c0 .3-.2.5-.5.5zM2 17h-.5c-.3 0-.5-.2-.5-.5v-4c0-.3.2-.5.5-.5s.5.2.5.5v4c0 .3-.2.5-.5.5z"/></svg>
              </a>
              <a href="https://www.youtube.com/@OBNM_BeatPioneer" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 6.4c-.3-1.1-1.1-1.9-2.2-2.2C18.9 3.7 12 3.7 12 3.7s-6.9 0-8.8.5C2.1 4.5 1.3 5.3 1 6.4.5 8.3.5 12 .5 12s0 3.7.5 5.6c.3 1.1 1.1 1.9 2.2 2.2 1.9.5 8.8.5 8.8.5s6.9 0 8.8-.5c1.1-.3 1.9-1.1 2.2-2.2.5-1.9.5-5.6.5-5.6s0-3.7-.5-5.6zM9.7 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg>
              </a>
              <a href="https://www.tiktok.com/@oscarbonomi_obnm" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 6.4c-1.7-.4-3-1.6-3.5-3.2v-.7h-3v12.3c0 1.7-1.4 3-3 3s-3-1.4-3-3 1.4-3 3-3c.3 0 .6 0 .9.1V8.8c-.3 0-.6-.1-.9-.1-3.4 0-6.1 2.7-6.1 6.1S6.7 21 10.1 21s6.1-2.7 6.1-6.1V9.4c1.3.9 2.9 1.5 4.5 1.5V8c-.4 0-.7-.1-1.1-.2v-1.4z"/></svg>
              </a>
            </nav>
          </div>
        </div>
      </section>
    </main>

    <footer class="demo-footer">
      <div class="container">
        <p>© {new Date().getFullYear()} Oscar Bonomi · OBNM · Hamburg</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --color-bg: #0A0A0A;
        --color-bg-card: #141414;
        --color-fg: #F5F1EA;
        --color-fg-dim: #9E9590;
        --color-accent: #E8A857;
        --color-border: rgba(245, 241, 234, 0.08);
        --font-display: 'Fraunces', Georgia, serif;
        --font-body: 'Inter', system-ui, sans-serif;
        --radius-card: 12px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--color-bg);
        color: var(--color-fg);
        font-family: var(--font-body);
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        background:
          radial-gradient(ellipse 1200px 800px at 50% -200px, rgba(232, 168, 87, 0.05) 0%, transparent 60%),
          var(--color-bg);
        min-height: 100vh;
      }
      a { color: inherit; text-decoration: none; }
      h1, h2, h3 {
        font-family: var(--font-display);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.1;
        margin: 0 0 24px;
      }
      .container {
        max-width: 760px;
        margin: 0 auto;
        padding: 0 24px;
      }
      .eyebrow {
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--color-accent);
        margin: 0 0 16px;
      }
      .demo-header {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 50;
        background: rgba(10, 10, 10, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--color-border);
        padding: 4px 20px;
      }
      .demo-header .brand {
        display: flex;
        align-items: center;
        gap: 0;
        font-family: var(--font-display);
        font-size: 1.125rem;
        font-weight: 600;
        max-width: 760px;
        margin: 0 auto;
      }
      .demo-header .brand-logo {
        width: 56px;
        height: 56px;
        object-fit: contain;
        border-radius: 50%;
        display: block;
      }
      .demo-header .brand-name {
        white-space: nowrap;
      }
      .hero {
        position: relative;
        min-height: 90vh;
        display: flex;
        align-items: center;
        padding: 140px 0 80px;
        overflow: hidden;
      }
      .hero-bg {
        position: absolute;
        inset: 0;
        z-index: 0;
      }
      .hero-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(20%) contrast(1.1);
      }
      .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(180deg, rgba(10,10,10,0.55) 0%, rgba(10,10,10,0.9) 100%);
      }
      .hero-content {
        position: relative;
        z-index: 1;
      }
      .hero h1 {
        font-size: clamp(2.75rem, 9vw, 5.5rem);
        font-weight: 500;
        line-height: 0.95;
        font-variation-settings: "opsz" 144;
      }
      .hero .hl {
        color: var(--color-accent);
        font-style: italic;
      }
      .manifesto {
        padding: 80px 0;
        border-top: 1px solid var(--color-border);
      }
      .manifesto .lead {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 4vw, 2.25rem);
        font-style: italic;
        color: var(--color-fg);
        margin: 0 0 32px;
        font-variation-settings: "opsz" 72;
        line-height: 1.3;
      }
      .manifesto p {
        font-size: 1.0625rem;
        line-height: 1.75;
        color: var(--color-fg);
        margin: 0 0 20px;
        max-width: 720px;
      }
      .player {
        padding: 80px 0;
        border-top: 1px solid var(--color-border);
      }
      .player h2 {
        font-size: clamp(1.75rem, 4vw, 2.5rem);
      }
      .player-frame {
        margin-top: 32px;
        border-radius: var(--radius-card);
        overflow: hidden;
        border: 1px solid var(--color-border);
        background: var(--color-bg-card);
      }
      .player-frame iframe {
        display: block;
        width: 100%;
        border: 0;
      }
      .cta {
        padding: 80px 0 100px;
        border-top: 1px solid var(--color-border);
      }
      .cta .container {
        display: grid;
        grid-template-columns: 1fr 1.2fr;
        gap: 48px;
        align-items: center;
      }
      .cta .portrait {
        margin: 0;
      }
      .cta .portrait img {
        width: 100%;
        height: auto;
        max-height: 70vh;
        object-fit: cover;
        border-radius: var(--radius-card);
        display: block;
      }
      .cta h2 {
        font-size: clamp(2rem, 5vw, 3rem);
      }
      .cta p {
        font-size: 1.0625rem;
        line-height: 1.7;
        margin: 0 0 32px;
      }
      .email-display {
        display: inline-block;
        font-family: var(--font-display);
        font-size: clamp(1.25rem, 3vw, 1.75rem);
        font-style: italic;
        color: var(--color-accent);
        margin-bottom: 32px;
        word-break: break-all;
        font-variation-settings: "opsz" 72;
      }
      .email-display:hover {
        text-decoration: underline;
        text-underline-offset: 6px;
      }
      .social {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
      }
      .social a {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 44px;
        height: 44px;
        border-radius: 50%;
        background: var(--color-bg-card);
        border: 1px solid var(--color-border);
        color: var(--color-fg);
        transition: all 0.25s ease;
      }
      .social a:hover {
        border-color: var(--color-accent);
        color: var(--color-accent);
        transform: translateY(-2px);
      }
      .social svg { width: 18px; height: 18px; }
      .demo-footer {
        border-top: 1px solid var(--color-border);
        padding: 20px 0 16px;
      }
      .demo-footer p {
        font-size: 0.75rem;
        color: var(--color-fg-dim);
        letter-spacing: 0.04em;
        margin: 0;
        text-align: center;
      }
      @media (max-width: 768px) {
        .demo-header { padding: 4px 12px; }
        .demo-header .brand-logo { width: 44px; height: 44px; }
        .demo-header .brand-name { font-size: 1rem; }
        .cta .container { grid-template-columns: 1fr; gap: 32px; }
        .cta .portrait { order: -1; }
        .manifesto { padding: 56px 0; }
        .player { padding: 56px 0; }
        .cta { padding: 56px 0 80px; }
        .player-frame iframe { height: 360px; }
      }
    </style>
  </body>
</html>
