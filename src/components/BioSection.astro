---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="bio" class="section bio">
  <div class="container-narrow">
    <p class="eyebrow">{t.bio.eyebrow}</p>
    <h2 class="title">{t.bio.title}</h2>
    <div class="bio-layout">
      <div class="bio-body">
        {t.bio.body.map((p) => <p>{p}</p>)}
      </div>
      <figure class="bio-portrait">
        <img src="/assets/Bio-1.jpg" alt="Oscar Bonomi, OBNM" loading="lazy" />
      </figure>
    </div>
    <div class="bio-gallery">
      <figure>
        <img src="/assets/Bio-2.jpg" alt="" aria-hidden="true" loading="lazy" />
      </figure>
      <figure>
        <img src="/assets/Bio-3.jpg" alt="" aria-hidden="true" loading="lazy" />
      </figure>
    </div>
  </div>
</section>

<style>
  .bio { border-top: 1px solid var(--color-border); }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 40px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .bio-layout {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .bio-body p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-fg);
    margin-bottom: 20px;
  }
  .bio-body p:first-child {
    font-size: 1.25rem;
    color: var(--color-fg);
  }
  .bio-portrait {
    margin: 0;
    position: sticky;
    top: 100px;
  }
  .bio-portrait img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    display: block;
  }
  .bio-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 56px;
  }
  .bio-gallery figure { margin: 0; }
  .bio-gallery img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    display: block;
  }
  @media (max-width: 820px) {
    .bio-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .bio-portrait { position: static; }
    .bio-gallery { grid-template-columns: 1fr; }
  }
</style>
