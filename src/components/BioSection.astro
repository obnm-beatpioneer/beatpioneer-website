---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="bio" class="section bio">
  <div class="container-narrow">
    <p class="eyebrow">{t.bio.eyebrow}</p>
    <h2 class="title">{t.bio.title}</h2>
    <figure class="bio-portrait">
      <img src="/assets/Bio-1.jpg" alt="Oscar Bonomi, OBNM" loading="lazy" />
    </figure>
    <div class="bio-body">
      {t.bio.body.map((p) => <p>{p}</p>)}
    </div>
    <figure class="bio-landscape">
      <img src="/assets/Bio-2.jpg" alt="" aria-hidden="true" loading="lazy" />
    </figure>
  </div>
</section>

<style>
  .bio { border-top: 1px solid var(--color-border); }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 40px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .bio-portrait {
    margin: 0 0 48px;
  }
  .bio-portrait img {
    width: 100%;
    height: auto;
    max-height: 70vh;
    object-fit: cover;
    object-position: center top;
    border-radius: var(--radius-card);
    display: block;
  }
  .bio-body p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-fg);
    margin-bottom: 20px;
    max-width: 720px;
  }
  .bio-body p:first-child {
    font-size: 1.25rem;
    color: var(--color-fg);
  }
  .bio-landscape {
    margin: 56px 0 0;
  }
  .bio-landscape img {
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    border-radius: var(--radius-card);
    display: block;
  }
  @media (max-width: 820px) {
    .bio-portrait img { max-height: 60vh; }
    .bio-landscape img { aspect-ratio: 4 / 3; }
  }
</style>
