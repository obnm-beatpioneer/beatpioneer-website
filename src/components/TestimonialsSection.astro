---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="testimonials" class="section testimonials">
  <div class="container-narrow">
    <p class="eyebrow">{t.testimonials.eyebrow}</p>
    <h2 class="title">{t.testimonials.title}</h2>
    <div class="grid">
      {t.testimonials.items.map((person) => (
        <article class="card">
          <div class="card-head">
            <figure class="avatar">
              <img src={person.photo} alt={person.name} loading="lazy" />
            </figure>
            <div class="who">
              <div class="name">{person.name}</div>
              <div class="role">{person.role}</div>
            </div>
          </div>
          <blockquote>{person.quote}</blockquote>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .testimonials { border-top: 1px solid var(--color-border); }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 48px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 28px;
  }
  .card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-card);
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .card-head {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .avatar {
    margin: 0;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
  }
  .avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .name {
    font-weight: 500;
    color: var(--color-accent);
    font-size: 1rem;
    margin-bottom: 2px;
  }
  .role {
    font-size: 0.8rem;
    color: var(--color-fg-dim);
    letter-spacing: 0.04em;
  }
  blockquote {
    font-family: var(--font-display);
    font-size: 1.0625rem;
    line-height: 1.6;
    font-style: italic;
    color: var(--color-fg);
    margin: 0;
    font-variation-settings: "opsz" 36;
  }
</style>
