---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="home" class="hero">
  <div class="container-narrow">
    <p class="eyebrow">{t.home.eyebrow}</p>
    <h1 class="hero-title">{t.home.title}</h1>
    <p class="hero-subtitle">{t.home.subtitle}</p>
    <p class="hero-intro">{t.home.intro}</p>
    <a href={t.home.ctaUrl} target="_blank" rel="noopener noreferrer" class="btn">
      {t.home.cta}
    </a>
  </div>
</section>

<style>
  .hero {
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-top: 120px;
    padding-bottom: 64px;
  }
  .hero-title {
    font-size: clamp(2.75rem, 8vw, 5.5rem);
    line-height: 1;
    margin-bottom: 24px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .hero-subtitle {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    line-height: 1.3;
    font-weight: 400;
    font-style: italic;
    color: var(--color-fg);
    margin-bottom: 32px;
    max-width: 560px;
    font-variation-settings: "opsz" 72;
  }
  .hero-intro {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-fg-dim);
    margin-bottom: 40px;
    max-width: 520px;
  }
</style>
