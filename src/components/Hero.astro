---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="home" class="hero">
  <div class="hero-bg">
    <img src="/assets/Hero-1.jpg" alt="" aria-hidden="true" loading="eager" />
    <div class="hero-overlay"></div>
  </div>
  <div class="container-narrow hero-content">
    <p class="eyebrow">{t.home.eyebrow}</p>
    <h1 class="hero-title">{t.home.title}</h1>
    <div class="hero-intro">
      {t.home.intro.map((p) => <p>{p}</p>)}
    </div>
    <a href="#contact" class="btn">{t.nav.contact}</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: 240px;
    padding-bottom: 80px;
    overflow: hidden;
  }
  @media (max-width: 768px) {
    .hero { padding-top: 180px; }
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(15%) contrast(1.05);
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.55) 0%, rgba(10,10,10,0.88) 100%);
  }
  .hero-content {
    position: relative;
    z-index: 1;
  }
  .hero-title {
    font-size: clamp(2.75rem, 8vw, 5.5rem);
    line-height: 1;
    margin-bottom: 24px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .hero-intro {
    margin-bottom: 40px;
  }
  .hero-intro p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-fg);
    margin-bottom: 16px;
    max-width: 580px;
  }
</style>
