---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
import SocialIcons from './SocialIcons.astro';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="contact" class="contact">
  <div class="contact-bg">
    <img src="/assets/Hero-1.jpg" alt="" aria-hidden="true" loading="lazy" />
    <div class="contact-overlay"></div>
  </div>
  <div class="container-narrow contact-content">
    <p class="eyebrow">{t.contact.eyebrow}</p>
    <h2 class="title">{t.contact.title}</h2>
    <p class="body">{t.contact.body}</p>
    <a href={`mailto:${t.contact.email}`} class="email-display">{t.contact.email}</a>
    <SocialIcons />
  </div>
</section>

<style>
  .contact {
    position: relative;
    padding: 120px 0 100px;
    border-top: 1px solid var(--color-border);
    overflow: hidden;
  }
  .contact-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .contact-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: grayscale(15%) contrast(1.05);
  }
  .contact-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.78) 0%, rgba(10,10,10,0.92) 100%);
  }
  .contact-content {
    position: relative;
    z-index: 1;
  }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 24px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-fg);
    margin-bottom: 36px;
    max-width: 560px;
  }
  .email-display {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: 40px;
    font-variation-settings: "opsz" 72;
    word-break: break-all;
  }
  .email-display:hover {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 1px;
  }
</style>
