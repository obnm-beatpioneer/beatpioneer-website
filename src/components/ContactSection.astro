---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
import SocialIcons from './SocialIcons.astro';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="contact" class="section contact">
  <div class="container-narrow">
    <p class="eyebrow">{t.contact.eyebrow}</p>
    <h2 class="title">{t.contact.title}</h2>
    <p class="body">{t.contact.body}</p>
    <div class="cta-row">
      <a href={t.home.ctaUrl} target="_blank" rel="noopener noreferrer" class="btn">{t.contact.cta}</a>
      <a href={`mailto:${t.contact.email}`} class="email-link">{t.contact.email}</a>
    </div>
    <SocialIcons />
  </div>
</section>

<style>
  .contact { border-top: 1px solid var(--color-border); padding-bottom: 64px; }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 24px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-fg);
    margin-bottom: 36px;
    max-width: 520px;
  }
  .cta-row {
    display: flex;
    align-items: center;
    gap: 28px;
    margin-bottom: 48px;
    flex-wrap: wrap;
  }
  .email-link {
    color: var(--color-fg);
    font-size: 0.95rem;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }
  .email-link:hover { color: var(--color-accent); }
</style>
