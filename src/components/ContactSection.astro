---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
import SocialIcons from './SocialIcons.astro';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
---
<section id="contact" class="section contact">
  <div class="container-narrow contact-layout">
    <div class="contact-text">
      <p class="eyebrow">{t.contact.eyebrow}</p>
      <h2 class="title">{t.contact.title}</h2>
      <p class="body">{t.contact.body}</p>
      <a href={`mailto:${t.contact.email}`} class="email-display">{t.contact.email}</a>
      <SocialIcons />
    </div>
    <figure class="contact-image">
      <img src="/assets/Contact.jpg" alt="" aria-hidden="true" loading="lazy" />
    </figure>
  </div>
</section>

<style>
  .contact {
    border-top: 1px solid var(--color-border);
    padding-bottom: 80px;
  }
  .contact-layout {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 24px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .body {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--color-fg);
    margin-bottom: 36px;
    max-width: 480px;
  }
  .email-display {
    display: inline-block;
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-style: italic;
    font-weight: 400;
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: 40px;
    font-variation-settings: "opsz" 72;
    word-break: break-all;
  }
  .email-display:hover {
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 1px;
  }
  .contact-image {
    margin: 0;
  }
  .contact-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    display: block;
    filter: grayscale(10%);
  }
  @media (max-width: 820px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .contact-image { order: -1; }
  }
</style>
