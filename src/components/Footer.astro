---
import { getLangFromUrl, useTranslations, getLocalizedPath, type Lang } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);
const home = getLocalizedPath(lang);
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container-narrow">
    <div class="footer-top">
      <a href={home} class="brand">
        <img src="/assets/logo-obnm.png" alt="OBNM" class="brand-logo" />
        <span class="brand-name">BeatPioneer</span>
      </a>
      <ul class="nav-links">
        <li><a href={`${home}#bio`}>{t.nav.bio}</a></li>
        <li><a href={`${home}#studio`}>{t.nav.studio}</a></li>
        <li><a href={`${home}#testimonials`}>{t.nav.testimonials}</a></li>
        <li><a href={`${home}#contact`}>{t.nav.contact}</a></li>
      </ul>
    </div>
    <div class="footer-bottom">
      <p class="tagline">{t.footer.tagline}</p>
      <p class="legal">© {year} Oscar Bonomi · OBNM · {t.footer.location} · {t.footer.rights}</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 16px 0 14px;
    margin-top: 24px;
  }
  .footer-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0;
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--color-fg);
  }
  .brand-logo {
    width: 192px;
    height: 192px;
    object-fit: contain;
    display: block;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .brand-name {
    white-space: nowrap;
  }
  .nav-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 24px;
    font-size: 0.85rem;
    flex-wrap: wrap;
  }
  .nav-links a {
    color: var(--color-fg-dim);
  }
  .nav-links a:hover { color: var(--color-accent); }
  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-border);
    padding-top: 10px;
  }
  .tagline {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-accent);
    margin: 0;
  }
  .legal {
    font-size: 0.7rem;
    color: var(--color-fg-dim);
    letter-spacing: 0.04em;
    margin: 0;
  }
  @media (max-width: 768px) {
    .brand-logo { width: 56px; height: 56px; }
    .brand-name { font-size: 1rem; }
    .footer { padding: 12px 0 10px; margin-top: 16px; }
  }
  @media (max-width: 380px) {
    .brand-logo { width: 44px; height: 44px; }
    .brand-name { font-size: 0.9rem; }
  }
</style>
