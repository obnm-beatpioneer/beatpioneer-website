---
const socials = [
  { name: 'Instagram', url: 'https://www.instagram.com/obnm_beatpioneer/', icon: 'instagram' },
  { name: 'YouTube', url: 'https://www.youtube.com/@OBNM_BeatPioneer', icon: 'youtube' },
  { name: 'SoundCloud', url: 'https://soundcloud.com/oscar-bonomi', icon: 'soundcloud' },
  { name: 'TikTok', url: 'https://www.tiktok.com/@oscarbonomi_obnm', icon: 'tiktok' },
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/oscar-bonomi-7a536143/', icon: 'linkedin' },
];
---
<nav class="social" aria-label="Social channels">
  {socials.map((s) => (
    <a href={s.url} target="_blank" rel="noopener noreferrer" aria-label={s.name} title={s.name}>
      {s.icon === 'instagram' && (
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="5" ry="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
      )}
      {s.icon === 'youtube' && (
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M23 6.4c-.3-1.1-1.1-1.9-2.2-2.2C18.9 3.7 12 3.7 12 3.7s-6.9 0-8.8.5C2.1 4.5 1.3 5.3 1 6.4.5 8.3.5 12 .5 12s0 3.7.5 5.6c.3 1.1 1.1 1.9 2.2 2.2 1.9.5 8.8.5 8.8.5s6.9 0 8.8-.5c1.1-.3 1.9-1.1 2.2-2.2.5-1.9.5-5.6.5-5.6s0-3.7-.5-5.6zM9.7 15.6V8.4l6.2 3.6-6.2 3.6z"/></svg>
      )}
      {s.icon === 'soundcloud' && (
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M21 14.5c0 2-1.5 3.5-3.5 3.5h-7c-.3 0-.5-.2-.5-.5V9c0-.2.1-.4.3-.5 1-.4 2.1-.6 3.2-.6 3.7 0 6.7 2.7 7.4 6.2.1.1.1.3.1.4zM8 18H7c-.3 0-.5-.2-.5-.5v-7c0-.3.2-.5.5-.5s.5.2.5.5v7c0 .3-.2.5-.5.5zM5 18h-.5c-.3 0-.5-.2-.5-.5v-6c0-.3.2-.5.5-.5s.5.2.5.5v6c0 .3-.2.5-.5.5zM2 17h-.5c-.3 0-.5-.2-.5-.5v-4c0-.3.2-.5.5-.5s.5.2.5.5v4c0 .3-.2.5-.5.5z"/></svg>
      )}
      {s.icon === 'tiktok' && (
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 6.4c-1.7-.4-3-1.6-3.5-3.2v-.7h-3v12.3c0 1.7-1.4 3-3 3s-3-1.4-3-3 1.4-3 3-3c.3 0 .6 0 .9.1V8.8c-.3 0-.6-.1-.9-.1-3.4 0-6.1 2.7-6.1 6.1S6.7 21 10.1 21s6.1-2.7 6.1-6.1V9.4c1.3.9 2.9 1.5 4.5 1.5V8c-.4 0-.7-.1-1.1-.2v-1.4z"/></svg>
      )}
      {s.icon === 'linkedin' && (
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5C3.9 3 3 3.9 3 5v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM8.3 18.3H5.7V10h2.6v8.3zM7 8.7c-.8 0-1.5-.7-1.5-1.5S6.2 5.7 7 5.7s1.5.7 1.5 1.5S7.8 8.7 7 8.7zm11.3 9.6h-2.6v-4.5c0-1.1-.4-1.8-1.4-1.8-.8 0-1.2.5-1.4 1-.1.2-.1.5-.1.7v4.5h-2.6V10h2.6v1.1c.4-.5 1-1.3 2.4-1.3 1.8 0 3.1 1.2 3.1 3.7v4.8z"/></svg>
      )}
    </a>
  ))}
</nav>

<style>
  .social {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    transition: all 0.25s ease;
  }
  .social a:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }
  .social svg { width: 20px; height: 20px; }
</style>
