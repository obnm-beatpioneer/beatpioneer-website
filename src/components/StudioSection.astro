---
import { getLangFromUrl, useTranslations, type Lang } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url) as Lang;
const t = useTranslations(lang);

const tileImgStyle = "position:absolute !important;top:0 !important;left:0 !important;width:100% !important;height:100% !important;max-width:none !important;object-fit:cover !important;object-position:center !important;display:block !important;";
---
<section id="studio" class="section studio">
  <div class="container-narrow">
    <p class="eyebrow">{t.studio.eyebrow}</p>
    <h2 class="title">{t.studio.title}</h2>
    <figure class="studio-hero">
      <img src="/assets/Studio-4.jpg" alt="Pioneer Sound Lab" loading="lazy" />
    </figure>
    <div class="studio-body">
      {t.studio.body.map((p) => <p>{p}</p>)}
    </div>
    <div class="studio-gallery">
      <div class="studio-tile">
        <img src="/assets/Hero-2.jpg" alt="" aria-hidden="true" loading="lazy" style={tileImgStyle} />
      </div>
      <div class="studio-tile">
        <img src="/assets/Hero-2.jpg" alt="" aria-hidden="true" loading="lazy" style={tileImgStyle} />
      </div>
      <div class="studio-tile">
        <img src="/assets/Hero-2.jpg" alt="" aria-hidden="true" loading="lazy" style={tileImgStyle} />
      </div>
    </div>
  </div>
</section>

<style>
  .studio { border-top: 1px solid var(--color-border); }
  .title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 40px;
    font-weight: 500;
    font-variation-settings: "opsz" 144;
  }
  .studio-hero {
    margin: 0 0 48px;
  }
  .studio-hero img {
    width: 100%;
    height: auto;
    max-height: 60vh;
    object-fit: cover;
    border-radius: var(--radius-card);
    display: block;
  }
  .studio-body p {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: var(--color-fg);
    margin-bottom: 20px;
    max-width: 720px;
  }
  .studio-gallery {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 56px;
  }
  .studio-tile {
    position: relative;
    aspect-ratio: 3 / 4;
    width: 100%;
    border-radius: var(--radius-card);
    overflow: hidden;
    background-color: var(--color-bg-card);
  }
  @media (max-width: 820px) {
    .studio-gallery {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .studio-tile {
      max-width: 480px;
      margin: 0 auto;
    }
  }
</style>
